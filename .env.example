# --- Hedera network -------------------------------------------------------
HEDERA_NETWORK=testnet
# Operator account (from https://portal.hedera.com/ — testnet faucet: 100 HBAR / 24h)
OPERATOR_ID=0.0.xxxxxx
OPERATOR_KEY=302e0201...            # DER-encoded ED25519 or ECDSA private key

# Vault account that custodies USDC + claim NFTs.
# For the MVP this can equal OPERATOR_ID; split them for a cleaner trust story.
VAULT_ID=0.0.xxxxxx

# --- Assets ---------------------------------------------------------------
# Native Circle USDC on Hedera testnet (6 decimals). Faucet: https://faucet.circle.com/
USDC_TOKEN_ID=0.0.429274
# If the testnet USDC isn't faucet-fundable to your accounts, create a mock with
# scripts/bootstrap.ts and paste its id here (same code path).

# --- Resources created by `pnpm bootstrap` (paste the printed ids back here) -----
SHARE_TOKEN_ID=
CLAIM_NFT_TOKEN_ID=
NAV_TOPIC_ID=

# --- Read layer + EVM relay ----------------------------------------------
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com/api/v1
HASHIO_RPC_URL=https://testnet.hashio.io/api      # Hedera EVM relay, chain id 296 (for Privy)

# --- Protocol params ------------------------------------------------------
PROTOCOL_FEE_BPS=10                 # 0.10% fractional fee on the share token
NAV_HEARTBEAT_SECONDS=15            # how often to recompute + publish NAV

# --- API ------------------------------------------------------------------
PORT=8787
