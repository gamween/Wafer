{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["hardhat.config.cts", "scripts/deploy.ts", "scripts/smoke.ts", "scripts/enable-secondary.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist", "web", "src", "scripts/resolve-operator.ts"]
}
