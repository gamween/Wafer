# Wafer web — Hedera testnet (chain 296)
# OPTIONAL overrides. The live vault + helper addresses are AUTO-SYNCED from the
# repo-root deployments/testnet.json at build time (src/lib/config.js imports it),
# so a redeploy that rewrites that file propagates to the front with NO code change
# and NO .env. Copy this to `.env` only to point at a DIFFERENT deploy. Everything
# here is PUBLIC config (no private keys in the frontend). There is NO mock mode at
# ship — the app reads live and degrades gracefully when an address is unset.

# WaferVault contract EVM address (0x...). Overrides deployments.json vaultAddress.
# VITE_VAULT_ADDRESS=0x1C225685b026a210e649127a84c5df6527C29B35

# Default pool-0 share-token + claim-NFT EVM addresses (0x...). Normally read at
# runtime from the contract's pools(poolId) view; these are only pre-read fallbacks.
# VITE_SHARE_TOKEN=0x00000000000000000000000000000000008CcE56
# VITE_CLAIM_NFT=0x00000000000000000000000000000000008CCe57

# MockDeviceNFT helper (operator collateral escrow) + its collection.
# VITE_DEVICE_NFT=0xf12C12CeeD3a943228E1Ef72090897E00193847C
# VITE_DEVICE_COLLECTION=0x00000000000000000000000000000000008CCe5d

# MockRewardSource (demo reward cashflow keeper).
# VITE_REWARD_SOURCE=0x0636884c22289A69dB493B38c06f5161b08cdB7E

# SaucerSwap V1 testnet (secondary market, SPEC §10).
# VITE_SAUCER_ROUTER=0x0000000000000000000000000000000000004b40
# VITE_SAUCER_FACTORY=0x00000000000000000000000000000000000026e7
# VITE_WHBAR=0x0000000000000000000000000000000000003ad2

# Optional RPC / mirror overrides (defaults below are Hedera testnet public infra).
# VITE_RPC_URL=https://testnet.hashio.io/api
# VITE_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
